# Copy to .env for local runs. On GitHub Actions these are set as repo secrets/variables instead.

# Required: from @BotFather
TELEGRAM_BOT_TOKEN=
# Required: your numeric chat id (see README for how to get it)
TELEGRAM_CHAT_ID=

# Optional but recommended: a dedicated Solana RPC URL (Helius/Triton/Alchemy free tier).
# Falls back to the public, rate-limited RPC if left blank.
RPC_URL=

# Optional: minimum available liquidity (in debt-token units, e.g. USDG) to count as "available".
# 0 = alert on any positive amount.
THRESHOLD=0
